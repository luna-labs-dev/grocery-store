{
  "name": "backend",
  "description": "A grocery shopping app to control how much the user are spending before the end of the shopping event",
  "main": "index.js",
  "repository": "git@github.com:Poli-Labs/grocery-store-backend.git",
  "license": "MIT",
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/main/server.ts",
    "start": "node dist/src/main/server.js",
    "build": "tsup src/main/server.ts src/infrastructure/repositories/drizzle/setup/migrate.ts drizzle.config.ts --clean --format esm --splitting false",
    "typecheck": "tsc --noEmit",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "tsx src/infrastructure/repositories/drizzle/setup/migrate.ts",
    "db:studio": "drizzle-kit studio",
    "test": "vitest"
  },
  "dependencies": {
    "@clerk/express": "^1.4.14",
    "@clerk/fastify": "^2.6.26",
    "@fastify/cors": "^11.2.0",
    "@fastify/swagger": "^9.7.0",
    "@fastify/swagger-ui": "^5.2.5",
    "@opentelemetry/api": "^1.9.0",
    "@opentelemetry/auto-instrumentations-node": "^0.70.1",
    "@opentelemetry/exporter-trace-otlp-http": "^0.213.0",
    "@opentelemetry/instrumentation-pino": "^0.58.0",
    "@opentelemetry/resources": "^2.6.0",
    "@opentelemetry/sdk-node": "^0.213.0",
    "@opentelemetry/semantic-conventions": "^1.40.0",
    "@scalar/fastify-api-reference": "^1.44.26",
    "axios": "^1.7.2",
    "dotenv": "^16.4.5",
    "drizzle-orm": "^0.45.1",
    "fastify": "^5.7.4",
    "fastify-type-provider-zod": "^6.1.0",
    "postgres": "^3.4.4",
    "referral-codes": "^3.0.0",
    "reflect-metadata": "^0.2.2",
    "tsyringe": "^4.8.0",
    "uuid": "^9.0.1",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@faker-js/faker": "^8.4.1",
    "@types/node": "^20.5.1",
    "@types/qs": "^6.14.0",
    "@types/uuid": "^9.0.8",
    "drizzle-kit": "^0.31.9",
    "mockdate": "^3.0.5",
    "pino-prettier": "3.0.1-dev",
    "tsup": "^8.0.2",
    "tsx": "^4.11.0",
    "typescript": "^5.4.5",
    "vite-tsconfig-paths": "^4.3.2",
    "vitest": "^4.0.18"
  }
}
