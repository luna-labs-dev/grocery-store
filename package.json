{
  "name": "grocery-store",
  "version": "2.2.0",
  "description": "",
  "type": "module",
  "scripts": {
    "dev:front": "pnpm --filter frontend dev",
    "dev:back": "pnpm --filter backend dev",
    "commit": "cz",
    "lint": "biome check --write --unsafe apps/**/src apps/**/tests",
    "test": "vitest run --silent --reporter verbose",
    "test:watch": "vitest --silent --reporter verbose",
    "infra:up": "bash ./scripts/dev-up.sh",
    "infra:down": "docker compose -f docker-compose.dev.yml down",
    "db:up": "docker compose -f docker-compose.dev.yml up -d",
    "db:down": "docker compose -f docker-compose.dev.yml down",
    "prepare": "bash scripts/setup-hooks.sh"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "packageManager": "pnpm@10.29.3",
  "devDependencies": {
    "@biomejs/biome": "2.3.12",
    "@commitlint/cli": "^17.7.1",
    "@commitlint/config-conventional": "^17.7.0",
    "@playwright/test": "^1.58.2",
    "@types/node": "^25.2.0",
    "commitizen": "^4.3.1",
    "lint-staged": "^14.0.1",
    "orval": "^8.5.1",
    "typescript": "~5.9.3",
    "vitest": "^4.0.18"
  }
}
